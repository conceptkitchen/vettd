{
  "manifest_version": 3,
  "name": "Graded - AI Prompt Security Scanner",
  "version": "0.2.0",
  "description": "Trust grades for AI prompts. Scans for jailbreaks, injection attacks, credential harvesting, and more. Works on AI chats and prompt marketplaces.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://poe.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*"
      ],
      "js": ["scanner.js", "content.js"],
      "css": ["badge.css"]
    },
    {
      "matches": [
        "https://flowgpt.com/*",
        "https://www.flowgpt.com/*",
        "https://promptbase.com/*",
        "https://www.promptbase.com/*",
        "https://smith.langchain.com/*",
        "https://github.com/*/prompts*",
        "https://github.com/*/prompt*",
        "https://huggingface.co/*",
        "https://www.aimodels.fyi/*"
      ],
      "js": ["scanner.js", "marketplace.js"],
      "css": ["badge.css"]
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon48.png"
  }
}
